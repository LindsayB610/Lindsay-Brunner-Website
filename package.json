{
  "name": "lindsay-brunner-hugo-site",
  "version": "1.0.0",
  "description": "Lindsay Brunner's personal website built with Hugo",
  "author": "Lindsay Brunner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LindsayB610/lindsay-brunner-hugo-site"
  },
  "scripts": {
    "dev": "hugo server -D --buildFuture --bind 0.0.0.0",
    "build": "npm run build:react && npm run generate:og-images && hugo --gc --minify --cleanDestinationDir",
    "build:react": "vite build",
    "generate:og-images": "node scripts/generate-og-images.js",
    "generate:png": "node scripts/generate-png-from-svg.js",
    "generate:substack-banner": "node scripts/generate-substack-banner.js",
    "start": "hugo server -D --buildFuture --bind 0.0.0.0",
    "clean": "rm -rf public",
    "serve": "hugo server --bind 0.0.0.0",
    "test:html": "html-validate public/**/*.html",
    "test:links": "node scripts/check-links.js",
    "test:content": "node tests/content-checks.js",
    "test:homepage": "node tests/homepage-react-island.test.js",
    "test:default-branch": "node tests/default-branch-references.test.js",
    "test:accessibility": "node tests/react-accessibility-render.test.js",
    "test:spell": "node tests/spell-check.js",
    "test:spell:all": "node tests/spell-check.js --all",
    "test:og-images": "node tests/og-image-generation.test.js",
    "test:schedule": "node tests/schedule-posts.test.js",
    "test:search-json": "node tests/recipe-search-json.test.js",
    "test:nemesis": "node tests/nemesis-tracker.test.js",
    "test:recipe-template": "node tests/recipe-template.test.js",
    "test:dietary": "node tests/dietary-labels.test.js",
    "test:mobile:static": "node tests/mobile-responsive.test.js",
    "test:mobile:render": "node tests/react-mobile-render.test.js",
    "test:mobile": "npm run test:mobile:static && npm run test:mobile:render",
    "test:ai-exporter:page": "node tests/ai-chat-exporter-page.test.js",
    "test:ai-exporter:client": "node tests/ai-chat-exporter-client.test.js",
    "test:ai-exporter:interaction": "node tests/ai-chat-exporter-interaction.test.js",
    "test:ai-exporter:visual": "node tests/ai-chat-exporter-visual-contract.test.js",
    "test:ai-exporter:function": "node tests/ai-chat-exporter-function.test.js",
    "test:ai-exporter:boundary": "node tests/ai-chat-exporter-boundary.test.js",
    "test:ai-exporter:runtime": "node tests/ai-chat-exporter-runtime.test.js",
    "test:ai-exporter": "npm run test:ai-exporter:client && npm run test:ai-exporter:page && npm run test:ai-exporter:interaction && npm run test:ai-exporter:visual && npm run test:ai-exporter:function && npm run test:ai-exporter:boundary && npm run test:ai-exporter:runtime",
    "test": "npm run pretest && npm run test:html && npm run test:links && npm run test:content && npm run test:homepage && npm run test:default-branch && npm run test:accessibility && npm run test:spell && npm run test:og-images && npm run test:schedule && npm run test:search-json && npm run test:nemesis && npm run test:recipe-template && npm run test:dietary && npm run test:mobile && npm run test:ai-exporter",
    "pretest": "npm run build",
    "schedule-posts": "node scripts/schedule-posts.js",
    "check:hugo": "node scripts/check-hugo-version.js",
    "check:dependencies": "node scripts/check-dependencies.js",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:nemesis-photos": "node scripts/optimize-nemesis-photos.js",
    "cleanup:backups": "node scripts/optimize-images.js --cleanup-only"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "chatgpt-thread-exporter": "github:LindsayB610/chatgpt-thread-exporter",
    "clsx": "^2.1.1",
    "hugo-bin": "^0.149.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "pdfkit": "^0.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-wrap-balancer": "^1.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.56",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cspell": "^9.4.0",
    "html-validate": "^10.3.0",
    "js-yaml": "^4.1.0",
    "linkinator": "^7.6.1",
    "playwright": "^1.60.0",
    "shadcn": "^4.7.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "overrides": {
    "file-type": "^21.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "hugo",
    "static-site",
    "personal-website",
    "developer-advocacy",
    "content-strategy"
  ]
}
